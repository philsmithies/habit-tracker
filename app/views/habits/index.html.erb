<% content_for :title, "My habits" %>

<section class="flex flex-col gap-4 border-y border-[#edf1f6] bg-white/90 py-4 sm:flex-row sm:items-center">
  <%= form_with url: habits_path, method: :get, class: "relative min-w-0 flex-1" do |form| %>
    <svg class="pointer-events-none absolute left-4 top-1/2 size-4 -translate-y-1/2 text-[#8ea0ba]" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="8.5" cy="8.5" r="5.5"></circle>
      <path d="m13 13 4 4"></path>
    </svg>
    <%= form.search_field :q, value: params[:q], placeholder: "Search habits", class: "h-[43px] w-full rounded-[5px] border border-[#d8e1ed] bg-white pl-12 pr-24 text-[16px] text-[#344258] outline-none placeholder:text-[#91a1ba] focus:border-[#aebdd0]" %>
    <span class="pointer-events-none absolute right-4 top-1/2 hidden -translate-y-1/2 items-center gap-1 text-[10px] text-[#8ea0ba] sm:flex">
      <kbd class="rounded bg-[#e6ecf4] px-1.5 py-1">command</kbd>
      <kbd class="rounded bg-[#e6ecf4] px-1.5 py-1">K</kbd>
    </span>
  <% end %>

  <button type="button" class="h-[43px] rounded-[5px] border border-[#d8e1ed] bg-white px-4 text-[16px] font-medium text-[#344258] hover:bg-[#f9fafc]">
    Reorder <span class="ml-1 text-xs">◆</span>
  </button>

  <details class="relative" <%= "open" if @show_habit_form %>>
    <summary class="flex h-[43px] cursor-pointer list-none items-center rounded-[5px] border border-[#d8e1ed] bg-white px-4 text-[16px] font-medium text-[#344258] hover:bg-[#f9fafc]">
      Create habit <span class="ml-3 text-xs">⌄</span>
    </summary>
    <div class="absolute right-0 z-20 mt-2 w-80 overflow-hidden rounded-md border border-[#c9d5e4] bg-white shadow-xl" data-controller="habit-type">
      <div data-habit-type-target="chooser" <%= "hidden" if @show_habit_form %>>
        <p class="border-b border-[#d8e1ed] px-3 py-2 text-[13px] text-[#91a1ba]">Choose your habit type</p>
        <%= link_to habits_path(tracking_type: "number"), class: "block w-full px-3 py-2.5 text-left hover:bg-[#f7f9fc]", data: { action: "habit-type#select", habit_type: "number" } do %>
          <span class="block text-[17px] font-medium text-[#344258]"><span class="mr-2 font-bold">#</span>Number</span>
          <span class="mt-0.5 block text-[13px] leading-[17px] text-[#91a1ba]">Customizable unit, i.e. miles walked, pages read, or minutes meditated.</span>
        <% end %>
        <%= link_to habits_path(tracking_type: "checkbox"), class: "block w-full px-3 py-2.5 text-left hover:bg-[#f7f9fc]", data: { action: "habit-type#select", habit_type: "checkbox" } do %>
          <span class="block text-[17px] font-medium text-[#344258]"><span class="mr-2">☑</span>Checkbox</span>
          <span class="mt-0.5 block text-[13px] leading-[17px] text-[#91a1ba]">Track a task that can only be done once, i.e. Went to the gym, waking up before 7.</span>
        <% end %>
      </div>

      <%= form_with model: @habit, local: true, class: "space-y-3 p-4", data: { habit_type_target: "form" }, html: { hidden: !@show_habit_form } do |form| %>
        <div class="flex items-center gap-2">
          <button type="button" class="text-[#91a1ba] hover:text-[#344258]" data-action="habit-type#back" aria-label="Choose another habit type">←</button>
          <p class="font-medium text-[#344258]" data-habit-type-target="heading">Create a <%= @habit.number? ? "number" : "checkbox" %> habit</p>
        </div>
        <% if @habit.errors.any? %>
          <p class="text-sm text-rose-600"><%= @habit.errors.full_messages.to_sentence %></p>
        <% end %>
        <%= form.hidden_field :tracking_type, data: { habit_type_target: "type" } %>
        <%= form.text_field :name, required: true, placeholder: "Habit name", class: "h-10 w-full rounded border border-[#d8e1ed] px-3 outline-none focus:border-[#aebdd0]", data: { habit_type_target: "name" } %>
        <div data-habit-type-target="unit" <%= "hidden" unless @habit.number? %>>
          <%= form.text_field :unit, required: @habit.number?, maxlength: 30, placeholder: "Unit (e.g. pages, miles, minutes)", class: "h-10 w-full rounded border border-[#d8e1ed] px-3 outline-none focus:border-[#aebdd0]" %>
        </div>
        <div class="flex items-center gap-3">
          <%= form.color_field :color, value: @habit.color || "#10b981", class: "h-10 w-12 cursor-pointer rounded border border-[#d8e1ed] bg-white p-1", title: "Habit color" %>
          <%= form.submit "Create habit", class: "h-10 flex-1 cursor-pointer rounded bg-[#344258] px-4 font-medium text-white hover:bg-[#263449]" %>
        </div>
      <% end %>
    </div>
  </details>
</section>

<section class="mt-10 space-y-10">
  <% if @habits.empty? %>
    <div class="rounded-[6px] border border-dashed border-[#d8e1ed] bg-white p-12 text-center">
      <h2 class="text-xl font-semibold text-[#344258]"><%= params[:q].present? ? "No matching habits" : "Add your first habit" %></h2>
      <p class="mt-1 text-sm text-[#91a1ba]"><%= params[:q].present? ? "Try another search." : "Use Create habit to get started." %></p>
    </div>
  <% end %>

  <% @habits.each do |habit| %>
    <% selected_year = @selected_years.fetch(habit.id, Date.current.year) %>
    <% weeks = habit_calendar_weeks(selected_year) %>
    <% entries_by_date = habit.entries.index_by(&:occurred_on) %>
    <% maximum_value = entries_by_date.values.select { |entry| entry.occurred_on.year == selected_year }.filter_map(&:value).max %>
    <% today_entry = entries_by_date[Date.current] %>

    <article id="<%= dom_id(habit) %>" data-calendar-year="<%= selected_year %>" class="rounded-[6px] border border-[#d8e1ed] bg-white px-8 py-8 sm:px-8 sm:py-8" <%= tag.attributes(data: { controller: "number-entry", number_entry_open_value: @log_habit_id == habit.id }) if habit.number? %>>
      <div class="flex items-start justify-between">
        <h2 class="text-[26px] font-semibold leading-none text-[#344258]"><%= habit.name %></h2>
        <div class="flex items-center gap-5 text-[#c4d0df]">
          <details class="relative">
            <summary class="flex cursor-pointer list-none items-center gap-1 text-[#91a1ba] hover:text-[#344258]" title="Calendar year: <%= selected_year %>">
              <svg class="size-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <rect x="2.5" y="4" width="15" height="13.5" rx="2"></rect>
                <path d="M6 2.5v3M14 2.5v3M2.5 8h15"></path>
              </svg>
              <span class="text-xs font-medium"><%= selected_year %></span>
            </summary>
            <div class="absolute right-0 z-20 mt-2 w-28 overflow-hidden rounded-md border border-[#d8e1ed] bg-white py-1 text-sm font-medium text-[#526077] shadow-lg">
              <% habit_calendar_years(habit).each do |year| %>
                <%= link_to year, habits_path(q: params[:q], years: @selected_years.merge(habit.id => year), anchor: dom_id(habit)), class: "block px-3 py-2 hover:bg-[#f7f9fc] #{year == selected_year ? "text-[#344258]" : ""}" %>
              <% end %>
            </div>
          </details>
          <%= button_to "⋮", habit_path(habit), method: :delete, class: "text-xl leading-none hover:text-rose-500", form: { data: { turbo_confirm: "Delete #{habit.name} and its history?" } } %>
        </div>
      </div>

      <div class="mt-6 overflow-x-auto pb-2">
        <div class="grid min-w-[900px] grid-cols-[28px_1fr] gap-x-2">
          <div></div>
          <div class="grid gap-[3px] text-center text-[12px] text-[#526077]" style="grid-template-columns: repeat(<%= weeks.size %>, minmax(0, 1fr))">
            <% weeks.each do |week| %>
              <span class="h-4 whitespace-nowrap"><%= calendar_year_month_label_for(week, selected_year) %></span>
            <% end %>
          </div>

          <div class="grid grid-rows-7 gap-[3px] text-right text-[12px] leading-[13px] text-[#526077]">
            <span>Mon</span><span></span><span>Wed</span><span></span><span>Fri</span><span></span><span></span>
          </div>

          <div class="grid gap-[3px]" style="grid-template-columns: repeat(<%= weeks.size %>, minmax(0, 1fr))" aria-label="<%= selected_year %> calendar">
            <% weeks.each do |week| %>
              <div class="grid grid-rows-7 gap-[3px]">
                <% week.each do |date| %>
                  <% entry = entries_by_date[date] %>
                  <% if date.year != selected_year %>
                    <span class="size-[13px]"></span>
                  <% elsif entry %>
                    <%= button_to habit_entry_path(habit, entry), method: :delete, title: "#{date.to_fs(:long)} — #{habit.number? ? "#{entry.value.to_fs(:delimited)} #{habit.unit}" : "completed"}", class: "size-[13px] rounded-[2px] ring-1 ring-inset ring-black/5", style: "background-color: #{habit_entry_color(habit, entry, maximum_value: maximum_value)}", form: { class: "contents" } do %>
                      <span class="sr-only">Remove completion for <%= date.to_fs(:long) %></span>
                    <% end %>
                  <% elsif date <= Date.current %>
                    <% if habit.number? %>
                      <button type="button" title="Log <%= date.to_fs(:long) %>" class="size-[13px] rounded-[2px] bg-[#f0f4f8] ring-1 ring-inset ring-[#dfe7f0] hover:bg-[#e1e8f0]" data-action="number-entry#open" data-date="<%= date %>" data-date-label="<%= date.to_fs(:long) %>">
                        <span class="sr-only">Log value for <%= date.to_fs(:long) %></span>
                      </button>
                    <% else %>
                      <%= button_to habit_entries_path(habit), params: { occurred_on: date }, title: "Log #{date.to_fs(:long)}", class: "size-[13px] rounded-[2px] bg-[#f0f4f8] ring-1 ring-inset ring-[#dfe7f0] hover:bg-[#e1e8f0]", form: { class: "contents" } do %>
                        <span class="sr-only">Log completion for <%= date.to_fs(:long) %></span>
                      <% end %>
                    <% end %>
                  <% else %>
                    <span class="size-[13px] rounded-[2px] bg-white ring-1 ring-inset ring-[#344258]"></span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="mt-5 flex min-h-14 items-end justify-between gap-4">
        <div class="text-[15px] leading-6 text-[#91a1ba]">
          <p>Streak: <strong class="font-semibold text-[#344258]"><%= pluralize(habit.current_streak, "day") %></strong></p>
          <p>Average: <strong class="font-semibold text-[#344258]"><%= habit.number? ? "#{number_with_precision(habit.average_value, precision: 2)} #{habit.unit}" : number_with_precision(habit.entries.size / 52.0, precision: 2) %></strong></p>
        </div>

        <% if today_entry %>
          <%= button_to habit_entry_path(habit, today_entry), method: :delete, class: "rounded-[5px] border border-[#d8e1ed] bg-white px-3 py-2.5 text-[16px] font-medium text-[#344258] hover:bg-[#f9fafc]" do %>
            Undo today <span class="ml-2">←</span>
          <% end %>
        <% else %>
          <% if habit.number? %>
            <button type="button" class="rounded-[5px] border border-[#d8e1ed] bg-white px-3 py-2.5 text-[16px] font-medium text-[#344258] hover:bg-[#f9fafc]" data-action="number-entry#open" data-date="<%= Date.current %>" data-date-label="<%= Date.current.to_fs(:long) %>">
              Log today <span class="ml-2">→</span>
            </button>
          <% else %>
            <%= button_to habit_entries_path(habit), class: "rounded-[5px] border border-[#d8e1ed] bg-white px-3 py-2.5 text-[16px] font-medium text-[#344258] hover:bg-[#f9fafc]" do %>
              Log today <span class="ml-2">→</span>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <% if habit.number? %>
        <dialog class="number-entry-dialog w-[min(92vw,360px)] rounded-[8px] border border-[#d8e1ed] bg-white p-0 shadow-2xl" data-number-entry-target="dialog" data-action="click->number-entry#closeOnBackdrop">
          <%= form_with url: habit_entries_path(habit), class: "space-y-4 p-5", data: { action: "click->number-entry#stopPropagation" } do |form| %>
            <div>
              <h3 class="text-lg font-semibold text-[#344258]">Log <%= habit.name %></h3>
              <p class="mt-1 text-sm text-[#91a1ba]" data-number-entry-target="dateLabel"><%= Date.current.to_fs(:long) %></p>
            </div>
            <%= form.hidden_field :occurred_on, value: Date.current, data: { number_entry_target: "date" } %>
            <label class="block">
              <span class="mb-1 block text-sm text-[#526077]">Value in <%= habit.unit %></span>
              <%= form.number_field :value, required: true, step: "any", class: "h-11 w-full rounded border border-[#d8e1ed] px-3 text-[#344258] outline-none focus:border-[#aebdd0]", data: { number_entry_target: "value" } %>
            </label>
            <div class="flex justify-end gap-2">
              <button type="button" class="rounded px-4 py-2 text-[#526077] hover:bg-[#f7f9fc]" data-action="number-entry#close">Cancel</button>
              <%= form.submit "Log value", class: "cursor-pointer rounded bg-[#344258] px-4 py-2 font-medium text-white hover:bg-[#263449]" %>
            </div>
          <% end %>
        </dialog>
      <% end %>
    </article>
  <% end %>
</section>
