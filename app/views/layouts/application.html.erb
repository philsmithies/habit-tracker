<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Habit Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#ffffff">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Habits">
    <meta name="application-name" content="Habit Tracker">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-background min-h-screen text-[#344258] antialiased">
    <% if authenticated? %>
      <header class="site-header safe-area-header relative bg-white/85">
        <nav class="mx-auto flex min-h-24 max-w-[1040px] items-center justify-center px-4">
          <div class="flex items-center gap-8 whitespace-nowrap text-[16px] font-semibold">
            <%= link_to root_path, class: "flex items-center gap-2 text-[#344258]" do %>
              <span class="grid size-3.5 place-items-center rounded-[3px] bg-[#35c995] text-[10px] leading-none text-white">✓</span>
              My habits
            <% end %>
            <%= link_to embed_path, class: "flex items-center gap-2 #{current_page?(embed_path) ? "text-[#344258]" : "text-[#91a1ba]"}" do %>
              <span class="font-mono" aria-hidden="true">&lt;/&gt;</span>
              HTML embed
            <% end %>
            <details class="relative">
              <summary class="flex cursor-pointer list-none items-center gap-2 text-[#91a1ba]">
                <span aria-hidden="true">⚙</span>
                Settings
              </summary>
              <div class="settings-menu absolute right-0 mt-3 w-64 rounded-md border border-[#d8e1ed] bg-white p-3 text-sm font-normal shadow-lg">
                <p class="truncate text-[#7f8da3]"><%= Current.user.email_address %></p>
                <div hidden class="mt-3 rounded bg-[#f0f4f8] p-3 text-xs leading-5 text-[#526077]" data-controller="pwa-install" data-pwa-install-target="instructions">
                  On iPhone, tap Share, then <strong class="font-semibold text-[#344258]">Add to Home Screen</strong>.
                </div>
                <%= button_to "Sign out", session_path, method: :delete, class: "mt-3 w-full rounded border border-[#d8e1ed] px-3 py-2 text-left text-[#344258] hover:bg-[#f7f9fc]" %>
              </div>
            </details>
          </div>
        </nav>
      </header>
    <% end %>

    <% if notice %>
      <div class="mx-auto mt-4 max-w-[1040px] px-4">
        <p class="rounded-lg bg-emerald-50 px-4 py-3 text-sm text-emerald-800"><%= notice %></p>
      </div>
    <% end %>

    <% if alert %>
      <div class="mx-auto mt-4 max-w-[1040px] px-4">
        <p class="rounded-lg bg-rose-50 px-4 py-3 text-sm text-rose-800"><%= alert %></p>
      </div>
    <% end %>

    <main class="safe-area-content mx-auto w-full max-w-[1040px] px-1 py-4 sm:py-4">
      <%= yield %>
    </main>
  </body>
</html>
