<% content_for :title, "HTML embed" %>

<section class="border-y border-[#edf1f6] bg-white/90 px-4 py-8 sm:px-8">
  <p class="text-sm font-semibold text-emerald-600">HTML embed</p>
  <h1 class="mt-1 text-3xl font-semibold text-[#344258]">Show your habits anywhere</h1>
  <p class="mt-3 max-w-2xl text-[#718096]">Paste this iframe into any website that accepts custom HTML. The public view is read-only and updates as you log habits.</p>
</section>

<section class="mt-8 grid gap-8 px-4 lg:grid-cols-[minmax(0,420px)_1fr]">
  <div class="rounded-[6px] border border-[#d8e1ed] bg-white p-5" data-controller="clipboard">
    <label for="embed-code" class="text-sm font-semibold text-[#344258]">Embed code</label>
    <textarea id="embed-code" readonly rows="7" class="mt-3 w-full resize-none rounded border border-[#d8e1ed] bg-[#f8fafc] p-3 font-mono text-xs leading-5 text-[#526077]" data-clipboard-target="source"><%= @embed_code %></textarea>
    <button type="button" class="mt-3 rounded-[5px] bg-[#344258] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#263449]" data-action="clipboard#copy" data-clipboard-target="button">Copy code</button>

    <div class="mt-8 border-t border-[#edf1f6] pt-5">
      <h2 class="font-semibold text-[#344258]">Public URL</h2>
      <p class="mt-2 break-all text-sm text-[#718096]"><%= @embed_url %></p>
      <p class="mt-3 text-xs leading-5 text-[#91a1ba]">Anyone with this URL can view your habit names and completion history.</p>
      <%= button_to "Reset public link", embed_path, method: :patch, class: "mt-4 text-sm font-semibold text-rose-600 hover:text-rose-700", form: { data: { turbo_confirm: "Reset the link? Existing embeds will stop working." } } %>
    </div>
  </div>

  <div>
    <p class="mb-3 text-sm font-semibold text-[#344258]">Preview</p>
    <iframe src="<%= @embed_url %>" title="Habit embed preview" class="h-[720px] w-full rounded-[6px] border border-[#d8e1ed] bg-white"></iframe>
  </div>
</section>
